{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteActionsOnLogArchives",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteBucket", 
        "s3:DeleteObject", 
        "s3:DeleteObjectVersion"
      ],
      "Resource": [
        "arn:aws:s3:::<BUCKET_NAME>",
        "arn:aws:s3:::<BUCKET_NAME>/*"
      ]
    }
  ]
}